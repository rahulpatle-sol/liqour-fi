# NeonDB PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/liqour?sslmode=require

# Redis (Upstash free tier)
REDIS_URL=redis://default:password@xxx.upstash.io:6379

# JWT Secret (min 64 chars)
JWT_SECRET=change_this_to_a_random_64_char_string_please_do_not_use_this_in_prod

# Server
PORT=3000
RUST_LOG=info

# Pyth Hermes (free public endpoint)
PYTH_HERMES_URL=https://hermes.pyth.network

# Pyth Price IDs
PYTH_SOL_ID=0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d
PYTH_BTC_ID=0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43
PYTH_ETH_ID=0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace

# Snapshot every 5 minutes
SNAPSHOT_INTERVAL_SECS=300

# Vault token account (created during anchor initialize)
VAULT_TOKEN_ACCOUNT=

# Backend keypair for signing withdraws (default: ~/.config/solana/id.json)
BACKEND_KEYPAIR_PATH=

# SQLx offline mode for deployment (set to "true" on Render)
SQLX_OFFLINE=true
